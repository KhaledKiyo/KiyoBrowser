{
  "name": "kiyobrowser",
  "version": "2.0.0-BETA",
  "description": "High-performance, Arch-inspired web browser.",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.khaled.kiyobrowser",
    "productName": "Kiyo Browser",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "portable"
      ],
      "icon": "public/kiyo_icon.ico"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "public/kiyo_icon.png"
    }
  }
}